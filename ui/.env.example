# Optional guest hub defaults baked into the production bundle at build time.
# Copy to .env.local for local dev; CI sets these from GitHub secrets (see .github/workflows/build.yml).
#
# Preferred (one secret, same as legacy -access-key / Playwright ?accessKey=):
VITE_HUB_ACCESS_KEY=
#
# Alternative — separate Basic Auth fields (used when VITE_HUB_ACCESS_KEY is empty):
VITE_HUB_AUTH_USER=
VITE_HUB_AUTH_PASS=
